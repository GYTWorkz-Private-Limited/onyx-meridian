# Onyx Meridian — copy to .env and adjust.

APP_NAME="Onyx Meridian API"
ENV=development
DEBUG=true
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8010

# Persistence. Leave unset to use the in-memory store (dev/tests, zero infra).
# Must include a default database name, e.g. .../meridian.
# MONGO_DB_URL=mongodb://localhost:27017/meridian

# Model gateway (Vault). Unset = local no-op gateway with on-prem-first routing.
# MODEL_GATEWAY_URL=http://localhost:4000
DEFAULT_MODEL=internal/onyx-llm

# Monitoring: a deployed employee silent for this many seconds is "stale".
HEARTBEAT_STALE_SECONDS=900

# Vault: pepper for hashing agent-principal credentials. MUST be set in prod.
CREDENTIAL_PEPPER=meridian-dev-pepper-change-me
